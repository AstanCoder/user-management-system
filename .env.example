POSTGRES_DB=contacts
POSTGRES_USER=contacts
POSTGRES_PASSWORD=contacts
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/contacts
SPRING_DATASOURCE_USERNAME=contacts
SPRING_DATASOURCE_PASSWORD=contacts

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

JWT_SECRET=change-me-to-a-secure-secret-at-least-32-characters
JWT_EXPIRATION_HOURS=24
APP_SECURITY_TOKEN_HASH_SECRET=change-me-to-a-different-secure-secret
APP_IDENTITY_PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
APP_IDENTITY_INVITATION_TOKEN_EXPIRATION_HOURS=24
APP_SECURITY_RATE_LIMIT_LOGIN_CAPACITY_PER_MINUTE=20
APP_SECURITY_RATE_LIMIT_LOGIN_FAILURE_CAPACITY_PER_15_MINUTES=10
APP_SECURITY_RATE_LIMIT_FORGOT_PASSWORD_CAPACITY_PER_HOUR=8

# Docker Compose uses Mailhog by default (see docker/docker-compose.yml)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Local backend without Docker — point at Mailhog on localhost:
# MAIL_HOST=localhost
# MAIL_PORT=1025

# Or use Mailtrap instead:
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true

APP_MAIL_FROM=noreply@nexuscrm.com

APP_AVATAR_STORAGE_PATH=./data/avatars

NEXT_PUBLIC_API_URL=http://localhost:8080

APP_SEED_TARGET_CONTACTS=1200
APP_SEED_TARGET_USERS=24
